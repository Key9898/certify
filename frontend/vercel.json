{
  "rewrites": [
    { "source": "/dashboard", "destination": "/index.html" },
    { "source": "/templates", "destination": "/index.html" },
    { "source": "/templates/new", "destination": "/index.html" },
    { "source": "/create", "destination": "/index.html" },
    { "source": "/certificates", "destination": "/index.html" },
    { "source": "/batch", "destination": "/index.html" },
    { "source": "/integrations", "destination": "/index.html" },
    { "source": "/settings", "destination": "/index.html" },
    { "source": "/verify", "destination": "/index.html" },
    { "source": "/verify/:certificateId", "destination": "/index.html" },
    { "source": "/about", "destination": "/index.html" },
    { "source": "/faq", "destination": "/index.html" },
    { "source": "/privacy", "destination": "/index.html" },
    { "source": "/terms", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
